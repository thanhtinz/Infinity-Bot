DATABASE_URL=
DB_SYNC=true
BOT_TOKEN=
CLIENT_ID=
OWNER_ID=
PREFIX=,
BOTBANNER=
SUPPORT_SERVER=

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
SERPAPI_API_KEY=
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=
BYTEZ_API_KEY=
TENOR_API_KEY=
TENOR_CLIENT_KEY=main_discord_bot

JOIN_LOGS_WEBHOOK_URL=
LEAVE_LOGS_WEBHOOK_URL=
SLASH_LOGS_WEBHOOK_URL=
PREFIX_LOGS_WEBHOOK_URL=
ERROR_LOGS_WEBHOOK_URL=
DM_LOGS_WEBHOOK_URL=

INFINITY_SYSTEM_PROMPT=
INFINITY_CASUAL_PROMPT=

# ---- Web Dashboard ----
# OAuth2 credentials for the "Login with Discord" flow. This is normally the SAME Discord
# Application as the bot, so DISCORD_CLIENT_ID can be left blank to fall back to CLIENT_ID above.
# DISCORD_CLIENT_SECRET must be generated from the Discord Developer Portal (Bot application ->
# OAuth2 -> Client Secret) and is required for the dashboard to log users in.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Add this exact URL as an OAuth2 redirect in the Discord Developer Portal.
DASHBOARD_CALLBACK_URL=http://localhost:3000/api/auth/discord/callback

# Where the dashboard's Express backend listens, and the public URL of the frontend it redirects
# back to after login (the Vite dev server in development, or the same origin in production).
DASHBOARD_PORT=3000
DASHBOARD_PUBLIC_URL=http://localhost:5173

# Long random string used to sign dashboard session cookies (sessions are stored in Postgres via
# connect-session-sequelize, reusing DATABASE_URL above). Generate with e.g. `openssl rand -hex 32`.
DASHBOARD_SESSION_SECRET=

# Shared secret + address for the bot<->dashboard status API (src/bot/dashboardApi.js). The
# dashboard backend calls this server-to-server to read live guild/channel/role/member data - the
# bot token itself is never exposed to the dashboard or the browser. Generate BOT_API_SECRET with
# e.g. `openssl rand -hex 32` and use the same value on both sides.
BOT_API_PORT=3002
BOT_API_SECRET=
BOT_API_BASE_URL=http://127.0.0.1:3002
