# Discord application
BOT_TOKEN=
CLIENT_ID=
OWNER_ID=
PREFIX=!

# PostgreSQL connection string
DATABASE_URL=
DB_SYNC=true

# Secret used to encrypt user-submitted AI provider API keys at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Optional: "tra phạt nguội" (traffic violation) lookup service for /phatnguoi.
# There is no official/documented public API for this (see PHATNGUOI_SETUP.md) — leave unset
# unless you have your own legitimate lookup service to point at. If set, the bot expects
# GET {PHATNGUOI_API_BASE_URL}/lookup?plate=...&type=... returning { "violations": [...] }.
PHATNGUOI_API_BASE_URL=
PHATNGUOI_API_KEY=
